<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
		x:CompileBindings="False"
        x:Class="DemoTest.CatalogWindow"
        Title="Список товаров">
	
	<DockPanel>

		<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" DockPanel.Dock="Top" Margin="5">
			<TextBox Watermark="Поиск" Width="200" Margin="5" Name="SearchBox" IsVisible="False" KeyUp="SearchBox_KeyUp"  FontFamily="Times New Roman"></TextBox>
			<ComboBox Margin="5" Width="200" Name="Sort"  IsVisible="False"  FontFamily="Times New Roman" SelectionChanged="Sort_SelectionChanged">
				<ComboBoxItem>по возрастанию</ComboBoxItem>
				<ComboBoxItem>по убыванию</ComboBoxItem>
			</ComboBox>
			
			<ComboBox Margin="5" Width="200" Name="Filter" IsVisible="False" SelectionChanged="Filter_SelectionChanged" FontFamily="Times New Roman"></ComboBox>
			<TextBlock x:Name="FioTextBlock" Text="" FontFamily="Times New Roman"></TextBlock>
		</StackPanel>
		
	<StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center">
		<Button Content="Назад" Margin="5" Click="Back_Click"  FontFamily="Times New Roman"></Button>
		<Button Content="Добавить товар" Margin="5" IsVisible="False" Click="Add_Click"  FontFamily="Times New Roman"></Button>
	</StackPanel>


	<ListBox Name="TovarsBox" SelectionChanged="TovarsBox_SelectionChanged" Background="#02f21e">
			<ListBox.ItemsPanel>
				<ItemsPanelTemplate>
					<UniformGrid Columns="1"></UniformGrid>
				</ItemsPanelTemplate>
			</ListBox.ItemsPanel>
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Border BorderBrush="Black" BorderThickness="1">
						<DockPanel>
							<Border BorderBrush="Black" BorderThickness="1" Margin="5" DockPanel.Dock="Left">
								<StackPanel  Orientation="Vertical" VerticalAlignment="Center">
									<Image Height="80" Width="80 " Margin="5" Source="{Binding GetPhoto}"></Image>
								</StackPanel>
							</Border>

							<Border BorderBrush="Black" BorderThickness="1" Margin="5" DockPanel.Dock="Right">
								<StackPanel  Orientation="Vertical" VerticalAlignment="Center">
									<TextBlock Text="{Binding Discount}"  Background="{Binding ColorDiscount}"  FontFamily="Times New Roman"></TextBlock>
								</StackPanel>
							</Border>

							<Border BorderBrush="Black" BorderThickness="1" Margin="5">
								<StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Center">
									<TextBlock Text="{Binding Description,StringFormat='Описание продукта:{0}'}"  FontFamily="Times New Roman" Margin="5"/>
									<TextBlock Text="{Binding Category.CategoryName,StringFormat='Категория продукта:{0}'}"  FontFamily="Times New Roman" Margin="5"/>
									<TextBlock Text="{Binding TovarType.TovarTypeName,StringFormat='Наименование продукта:{0}'}"  FontFamily="Times New Roman" Margin="5"/>
									<TextBlock Text="{Binding Supplier.SupplierName,StringFormat='Поставщик:{0}'}"  FontFamily="Times New Roman" Margin="5"/>
									<TextBlock Text="{Binding Manufacturer.ManufacturerName,StringFormat='Производитель продукта:{0}'}"  FontFamily="Times New Roman" Margin="5"/>
									<TextBlock Text="{Binding Price,StringFormat='Цена продукта:{0}'}"  FontFamily="Times New Roman" Margin="5"/>
									<TextBlock Text="{Binding Unit.UnitName,StringFormat='Ед.измерения:{0}'}"  FontFamily="Times New Roman" Margin="5"/>
									<TextBlock Text="{Binding Quantity,StringFormat='Количество продукта:{0}'}"  Background="{Binding ColorQuantity}"  FontFamily="Times New Roman" Margin="5"/>
								</StackPanel>
							</Border>
						</DockPanel>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>

	</DockPanel>

</Window>
